---
import { Search } from "lucide-react";
import { AuthStatus } from "@/components/auth/AuthStatus";
import { MobileNavigation } from "@/components/layout/MobileNavigation";
import { ThemeToggle } from "@/components/ThemeToggle";
import { TOOL_TUTORIALS_LABEL, TOOL_TUTORIALS_PATH } from "@/lib/content";

const navItems = [
  { href: "/", label: "首页" },
  { href: TOOL_TUTORIALS_PATH, label: TOOL_TUTORIALS_LABEL },
];
---

<header class="sticky top-0 z-40 border-b border-border bg-background/95 backdrop-blur">
  <div class="mx-auto flex h-14 max-w-[90rem] items-center justify-between px-4 sm:px-6">
    <div class="flex min-w-0 items-center">
      <a href="/" class="flex shrink-0 items-center gap-2 text-sm font-semibold">
        <span
          aria-hidden="true"
          class="flex h-7 w-7 items-center justify-center rounded-sm bg-primary text-xs text-primary-foreground"
        >
          E
        </span>
        <span>EggDoc</span>
      </a>
      <span class="mx-4 hidden h-5 w-px bg-border sm:block" aria-hidden="true"></span>
      <a
        class="hidden truncate text-sm font-medium text-muted-foreground hover:text-foreground sm:block"
        href={TOOL_TUTORIALS_PATH}
      >
        {TOOL_TUTORIALS_LABEL}
      </a>
    </div>
    <nav class="hidden items-center gap-1 lg:flex" aria-label="主导航">
      {navItems.map((item) => (
        <a
          class="px-3 py-2 text-sm text-muted-foreground transition-colors hover:text-foreground"
          href={item.href}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="flex shrink-0 items-center gap-1">
      <MobileNavigation client:load items={navItems} />
      <a
        aria-label="搜索"
        class="inline-flex h-10 w-10 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
        href="/search/"
        title="搜索"
      >
        <Search className="h-4 w-4" />
      </a>
      <ThemeToggle client:load />
      <div class="hidden md:block">
        <AuthStatus client:load />
      </div>
    </div>
  </div>
</header>
