---
import { Search } from "lucide-react";
import { AuthStatus } from "@/components/auth/AuthStatus";
import { ThemeToggle } from "@/components/ThemeToggle";

const navItems = [
  { href: "/", label: "首页" },
  { href: "/eggai/", label: "EggAi 指南" },
  { href: "/learn/", label: "AI 编程" },
  { href: "/notes/", label: "工具与概念" },
];
---

<header class="sticky top-0 z-40 border-b border-border bg-background/90 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4">
    <a href="/" class="flex items-center gap-2 text-sm font-semibold">
      <span
        aria-hidden="true"
        class="flex h-8 w-8 items-center justify-center rounded-md bg-primary text-primary-foreground"
      >
        E
      </span>
      <span>EggDoc</span>
    </a>
    <nav class="hidden items-center gap-1 md:flex" aria-label="主导航">
      {navItems.map((item) => (
        <a
          class="rounded-md px-3 py-2 text-sm text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
          href={item.href}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-1">
      <a
        aria-label="搜索"
        class="inline-flex h-10 w-10 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
        href="/search/"
        title="搜索"
      >
        <Search className="h-4 w-4" />
      </a>
      <ThemeToggle client:load />
      <AuthStatus client:load />
    </div>
  </div>
</header>
