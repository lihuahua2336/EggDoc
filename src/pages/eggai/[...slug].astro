---
import { getCollection, render } from "astro:content";
import ArticleLayout from "@/layouts/ArticleLayout.astro";
import { getGuideUrl, getRelatedEntries, isPublished } from "@/lib/content";

export async function getStaticPaths() {
  const guides = await getCollection("guides", (entry) => {
    return isPublished(entry) && entry.data.service === "eggai";
  });

  return guides.map((entry) => ({
    params: { slug: getGuideUrl(entry).replace(/^\/eggai\//, "").replace(/\/$/, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const related = await getRelatedEntries(entry);
---

<ArticleLayout entry={entry} headings={headings} related={related}>
  <Content />
</ArticleLayout>
