---
import ContentCard from "@/components/article/ContentCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPublishedGuides } from "@/lib/content";

const guides = await getPublishedGuides();
const eggaiGuides = guides.filter((guide) => guide.data.service === "eggai");
---

<BaseLayout title="EggAi 指南" description="EggAi 中转 API 的配置、接入和排错教程。">
  <main class="mx-auto max-w-6xl px-4 py-12">
    <header class="max-w-3xl">
      <p class="text-sm font-medium text-primary">Guide Collection</p>
      <h1 class="mt-3 text-3xl font-semibold md:text-4xl">EggAi 指南</h1>
      <p class="mt-4 text-lg leading-8 text-muted-foreground">
        面向具体配置任务的指南集。你可以按应用直接进入对应教程，也可以先阅读快速介绍。
      </p>
    </header>
    <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {eggaiGuides.map((entry) => <ContentCard entry={entry} />)}
    </div>
  </main>
</BaseLayout>
