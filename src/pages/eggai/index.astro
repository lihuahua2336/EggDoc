---
import ContentCard from "@/components/article/ContentCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getToolTutorials, TOOL_TUTORIALS_LABEL } from "@/lib/content";

const guides = await getToolTutorials();
---

<BaseLayout title={TOOL_TUTORIALS_LABEL} description="Codex 与 Claude Code 的快速安装教程。">
  <main class="mx-auto max-w-6xl px-4 py-12">
    <header class="max-w-3xl">
      <p class="text-sm font-medium text-primary">Tool Tutorials</p>
      <h1 class="mt-3 text-3xl font-semibold md:text-4xl">{TOOL_TUTORIALS_LABEL}</h1>
      <p class="mt-4 text-lg leading-8 text-muted-foreground">
        每篇文章只完成一个工具的安装。选择 Codex 或 Claude Code，复制命令即可开始。
      </p>
    </header>
    <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {guides.map((entry) => <ContentCard entry={entry} />)}
    </div>
  </main>
</BaseLayout>
