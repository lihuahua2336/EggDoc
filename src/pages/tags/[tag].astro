---
import ContentCard from "@/components/article/ContentCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getAllPublishedContent } from "@/lib/content";

export async function getStaticPaths() {
  const entries = await getAllPublishedContent();
  const tags = new Set(entries.flatMap((entry) => entry.data.tags));

  return Array.from(tags).map((tag) => ({
    params: { tag },
    props: {
      tag,
      entries: entries.filter((entry) => entry.data.tags.includes(tag)),
    },
  }));
}

const { tag, entries } = Astro.props;
---

<BaseLayout title={`标签：${tag}`} description={`浏览 EggDoc 中带有 ${tag} 标签的内容。`}>
  <main class="mx-auto max-w-6xl px-4 py-12">
    <header>
      <p class="text-sm font-medium text-primary">Tag</p>
      <h1 class="mt-3 text-3xl font-semibold md:text-4xl">#{tag}</h1>
      <p class="mt-4 text-lg leading-8 text-muted-foreground">
        共 {entries.length} 篇内容。
      </p>
    </header>
    <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {entries.map((entry) => <ContentCard entry={entry} />)}
    </div>
  </main>
</BaseLayout>
