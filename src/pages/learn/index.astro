---
import ContentCard from "@/components/article/ContentCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPublishedLessons } from "@/lib/content";

const lessons = await getPublishedLessons("ai-programming");
---

<BaseLayout title="AI 编程入门" description="从 Codex 安装到 EggDoc 项目实战的 AI 编程学习路径。">
  <main class="mx-auto max-w-6xl px-4 py-12">
    <header class="max-w-3xl">
      <p class="text-sm font-medium text-primary">Learning Path</p>
      <h1 class="mt-3 text-3xl font-semibold md:text-4xl">AI 编程入门</h1>
      <p class="mt-4 text-lg leading-8 text-muted-foreground">
        一条连续学习路径：先准备 Codex，再理解 AI 编程的核心概念，最后用 Astro 和 shadcn/ui 搭建 EggDoc。
      </p>
    </header>
    <ol class="mt-8 grid gap-4">
      {lessons.map((entry, index) => (
        <li class="grid gap-4 md:grid-cols-[3rem_minmax(0,1fr)]">
          <div class="flex h-10 w-10 items-center justify-center rounded-md border border-border bg-card text-sm font-semibold">
            {index + 1}
          </div>
          <ContentCard entry={entry} />
        </li>
      ))}
    </ol>
  </main>
</BaseLayout>
