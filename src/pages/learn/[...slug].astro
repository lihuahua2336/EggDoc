---
import { getCollection, render } from "astro:content";
import { articleMdxComponents } from "@/components/article/mdx-components";
import ArticleLayout from "@/layouts/ArticleLayout.astro";
import {
  getAdjacentLessons,
  getLessonUrl,
  getRelatedEntries,
  isPublished,
} from "@/lib/content";
import { isTestContentFixture } from "@/lib/content-test-fixtures";

export async function getStaticPaths() {
  const lessons = await getCollection("lessons", (entry) => {
    return isPublished(entry) || isTestContentFixture(entry);
  });

  return lessons.map((entry) => ({
    params: { slug: getLessonUrl(entry).replace(/^\/learn\//, "").replace(/\/$/, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const [adjacent, related] = await Promise.all([
  getAdjacentLessons(entry),
  getRelatedEntries(entry),
]);
---

<ArticleLayout entry={entry} adjacent={adjacent} headings={headings} related={related}>
  <Content components={articleMdxComponents} />
</ArticleLayout>
