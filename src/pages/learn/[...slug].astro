---
import { getCollection, render } from "astro:content";
import ArticleLayout from "@/layouts/ArticleLayout.astro";
import {
  getAdjacentLessons,
  getLessonUrl,
  getRelatedEntries,
  isPublished,
} from "@/lib/content";

export async function getStaticPaths() {
  const lessons = await getCollection("lessons", isPublished);

  return lessons.map((entry) => ({
    params: { slug: getLessonUrl(entry).replace(/^\/learn\//, "").replace(/\/$/, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const [adjacent, related] = await Promise.all([
  getAdjacentLessons(entry),
  getRelatedEntries(entry),
]);
---

<ArticleLayout entry={entry} adjacent={adjacent} headings={headings} related={related}>
  <Content />
</ArticleLayout>
