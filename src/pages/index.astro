---
import ContentCard from "@/components/article/ContentCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getToolTutorials,
  TOOL_TUTORIALS_DESCRIPTION,
  TOOL_TUTORIALS_LABEL,
} from "@/lib/content";

const homepageGuideIds = new Set([
  "eggai/claude-code-install",
  "eggai/codex-installer",
]);
const guides = (await getToolTutorials()).filter((entry) => homepageGuideIds.has(entry.id));
---

<BaseLayout title="EggDoc" description={TOOL_TUTORIALS_DESCRIPTION}>
  <main class="mx-auto max-w-6xl px-4 py-12 md:py-16">
    <header class="max-w-3xl">
      <p class="text-sm font-medium text-primary">Tool Tutorials</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-normal md:text-5xl">{TOOL_TUTORIALS_LABEL}</h1>
      <p class="mt-4 text-lg leading-8 text-muted-foreground">
        快速完成 Codex、Claude Code 安装，并按需了解 EggAi 配置。
      </p>
    </header>
    <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {guides.map((entry) => <ContentCard entry={entry} />)}
    </div>
  </main>
</BaseLayout>
