---
import ContentCard from "@/components/article/ContentCard.astro";
import { Button } from "@/components/ui/button";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getAllPublishedContent,
  getPublishedGuides,
  getPublishedLessons,
  getPublishedNotes,
} from "@/lib/content";

const [guides, lessons, notes, allContent] = await Promise.all([
  getPublishedGuides(),
  getPublishedLessons("ai-programming"),
  getPublishedNotes(),
  getAllPublishedContent(),
]);

const featured = allContent.filter((entry) => entry.data.featured).slice(0, 6);
---

<BaseLayout>
  <main>
    <section class="border-b border-border">
      <div class="mx-auto max-w-6xl px-4 py-16 md:py-20">
        <div class="max-w-3xl">
          <p class="text-sm font-medium text-primary">AI 教程、工具指南与编程学习路径</p>
          <h1 class="mt-4 text-4xl font-semibold tracking-normal md:text-5xl">
            EggDoc
          </h1>
          <p class="mt-5 text-lg leading-8 text-muted-foreground">
            收录 EggAi 接入教程、AI 编程入门课程、工具介绍和新概念解释。内容以中文 Markdown 为主，视频作为课程增强材料。
          </p>
        </div>
        <div class="mt-10 grid gap-4 md:grid-cols-2">
          <a
            class="rounded-lg border border-border bg-card p-6 transition-colors hover:border-primary/50"
            href="/eggai/"
          >
            <p class="text-sm font-medium text-primary">EggAi 指南</p>
            <h2 class="mt-3 text-2xl font-semibold">配置中转 API</h2>
            <p class="mt-3 leading-7 text-muted-foreground">
              在 Cursor、Cherry Studio 和其他应用中配置 EggAi，快速解决 API Key、Base URL 和模型连接问题。
            </p>
          </a>
          <a
            class="rounded-lg border border-border bg-card p-6 transition-colors hover:border-primary/50"
            href="/learn/"
          >
            <p class="text-sm font-medium text-primary">AI 编程入门</p>
            <h2 class="mt-3 text-2xl font-semibold">从 Codex 到项目实战</h2>
            <p class="mt-3 leading-7 text-muted-foreground">
              从安装 Codex 开始，理解 AI 编程概念，并把当前文档站作为完整实战项目搭建出来。
            </p>
          </a>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 py-12">
      <div class="flex items-end justify-between gap-4">
        <div>
          <h2 class="text-2xl font-semibold">推荐内容</h2>
          <p class="mt-2 text-muted-foreground">从最核心的指南和课程章节开始。</p>
        </div>
        <Button asChild variant="outline">
          <a href="/notes/">查看全部</a>
        </Button>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {featured.map((entry) => <ContentCard entry={entry} />)}
      </div>
    </section>

    <section class="border-t border-border bg-muted/40">
      <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 md:grid-cols-3">
        <div>
          <h2 class="text-xl font-semibold">当前内容概览</h2>
          <p class="mt-2 text-sm leading-6 text-muted-foreground">
            先用少量高价值内容把结构跑通，后续再逐步扩展。
          </p>
        </div>
        <div class="rounded-lg border border-border bg-card p-5">
          <p class="text-3xl font-semibold">{guides.length}</p>
          <p class="mt-1 text-sm text-muted-foreground">EggAi 指南</p>
        </div>
        <div class="rounded-lg border border-border bg-card p-5">
          <p class="text-3xl font-semibold">{lessons.length + notes.length}</p>
          <p class="mt-1 text-sm text-muted-foreground">课程与笔记</p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
