---
import ContentCard from "@/components/article/ContentCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPublishedNotes } from "@/lib/content";

const notes = await getPublishedNotes();
---

<BaseLayout title="工具与概念" description="AI 工具介绍、新概念解释和灵活笔记。">
  <main class="mx-auto max-w-6xl px-4 py-12">
    <header class="max-w-3xl">
      <p class="text-sm font-medium text-primary">Notes</p>
      <h1 class="mt-3 text-3xl font-semibold md:text-4xl">工具与概念</h1>
      <p class="mt-4 text-lg leading-8 text-muted-foreground">
        用较轻的文章收纳 AI 工具介绍、新概念解释和阶段性观察。
      </p>
    </header>
    <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {notes.map((entry) => <ContentCard entry={entry} />)}
    </div>
  </main>
</BaseLayout>
