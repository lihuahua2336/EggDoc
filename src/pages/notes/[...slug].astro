---
import { getCollection, render } from "astro:content";
import { articleMdxComponents } from "@/components/article/mdx-components";
import ArticleLayout from "@/layouts/ArticleLayout.astro";
import { getNoteUrl, getRelatedEntries, isPublished } from "@/lib/content";

export async function getStaticPaths() {
  const notes = await getCollection("notes", isPublished);

  return notes.map((entry) => ({
    params: { slug: getNoteUrl(entry).replace(/^\/notes\//, "").replace(/\/$/, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const related = await getRelatedEntries(entry);
---

<ArticleLayout entry={entry} headings={headings} related={related}>
  <Content components={articleMdxComponents} />
</ArticleLayout>
