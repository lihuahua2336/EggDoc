---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Check, Copy } from "lucide-react";
import {
  formatDate,
  getGuideUrl,
  getToolTutorials,
  TOOL_TUTORIALS_LABEL,
  TOOL_TUTORIALS_PATH,
  type ContentEntry,
} from "@/lib/content";

type Heading = {
  depth: number;
  slug: string;
  text: string;
};

interface Props {
  entry: ContentEntry;
  headings?: Heading[];
  related?: ContentEntry[];
}

const { entry, headings = [], related = [] } = Astro.props;
const toc = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const canonicalPath = getGuideUrl(entry);
const installGuides = await getToolTutorials();
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath={canonicalPath}
  type="article"
>
  <div class="border-b border-border bg-muted/35">
    <div class="mx-auto flex h-10 max-w-[90rem] items-center gap-2 px-4 text-sm text-muted-foreground sm:px-6">
      <a href="/" class="hover:text-foreground">EggDoc</a>
      <span aria-hidden="true">/</span>
      <a href={TOOL_TUTORIALS_PATH} class="hover:text-foreground">
        {TOOL_TUTORIALS_LABEL}
      </a>
      <span aria-hidden="true">/</span>
      <span class="truncate text-foreground">{entry.data.title}</span>
    </div>
  </div>

  <main class="mx-auto grid max-w-[90rem] grid-cols-1 lg:grid-cols-[15rem_minmax(0,46rem)] xl:grid-cols-[15rem_minmax(0,46rem)_13rem]">
    <aside class="hidden border-r border-border lg:block" aria-label="文档导航">
      <nav class="sticky top-14 max-h-[calc(100vh-3.5rem)] overflow-y-auto px-5 py-8">
        <a class="block text-sm font-semibold text-foreground" href={TOOL_TUTORIALS_PATH}>
          {TOOL_TUTORIALS_LABEL}
        </a>
        <p class="mt-6 text-xs font-semibold text-muted-foreground">安装</p>
        <ul class="mt-2 space-y-1 text-sm">
          {installGuides.map((guide) => (
            <li>
              <a
                aria-current={getGuideUrl(guide) === canonicalPath ? "page" : undefined}
                class:list={[
                  "block border-l-2 py-2 pl-3 leading-5 transition-colors",
                  getGuideUrl(guide) === canonicalPath
                    ? "border-primary font-semibold text-primary"
                    : "border-transparent text-muted-foreground hover:border-border hover:text-foreground",
                ]}
                href={getGuideUrl(guide)}
              >
                {guide.data.title}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>

    <article class="min-w-0 px-4 py-8 sm:px-8 lg:px-10 lg:py-10" data-pagefind-body>
      <header class="mb-8 border-b border-border pb-7">
        <p class="mb-3 text-sm text-muted-foreground">{TOOL_TUTORIALS_LABEL}</p>
        <h1 class="text-3xl font-semibold tracking-normal text-foreground md:text-[2.5rem] md:leading-[1.15]">
          {entry.data.title}
        </h1>
        <p class="mt-4 max-w-3xl text-base leading-7 text-muted-foreground md:text-lg">
          {entry.data.description}
        </p>
        <div class="mt-5 flex flex-wrap gap-x-5 gap-y-1 text-xs text-muted-foreground">
          <span>更新于 {formatDate(entry.data.updatedAt)}</span>
        </div>
      </header>

      <div class="prose max-w-none">
        <slot />
      </div>
      <p class="sr-only" aria-live="polite" data-code-copy-status></p>

      {
        related.length > 0 && (
          <section class="mt-12 border-t border-border pt-8">
            <h2 class="text-xl font-semibold">继续阅读</h2>
            <ul class="mt-4 divide-y divide-border border-y border-border">
              {related.slice(0, 3).map((item) => (
                <li>
                  <a class="flex items-center justify-between gap-4 py-4 hover:text-primary" href={getGuideUrl(item)}>
                    <span class="font-medium">{item.data.title}</span>
                    <span aria-hidden="true">→</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      <footer class="mt-10 flex flex-wrap gap-2 border-t border-border pt-6 text-xs text-muted-foreground">
        {entry.data.tags.map((tag) => <a class="hover:text-primary" href={`/tags/${tag}/`}>#{tag}</a>)}
      </footer>
    </article>

    <aside class="hidden xl:block">
      <div class="sticky top-14 px-5 py-10">
        {toc.length > 0 && (
          <nav class="border-l border-border pl-4" aria-label="本文内容">
            <p class="text-sm font-semibold">本文内容</p>
            <ol class="mt-3 space-y-2.5 text-sm text-muted-foreground">
              {toc.map((heading) => (
                <li class={heading.depth === 3 ? "pl-3" : ""}>
                  <a class="block leading-5 hover:text-foreground" href={`#${heading.slug}`}>
                    {heading.text}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        )}
      </div>
    </aside>
  </main>
</BaseLayout>

<template data-copy-icon><Copy aria-hidden="true" size={15} /></template>
<template data-check-icon><Check aria-hidden="true" size={15} /></template>

<script>
  const resetTimers = new WeakMap<HTMLButtonElement, number>();
  const languageNames: Record<string, string> = {
    bash: "Bash",
    powershell: "PowerShell",
    sh: "Shell",
    shell: "Shell",
    text: "Text",
    toml: "TOML",
    txt: "Text",
  };

  function setCopyButton(button: HTMLButtonElement, label: string, copied: boolean) {
    const template = document.querySelector<HTMLTemplateElement>(
      copied ? "template[data-check-icon]" : "template[data-copy-icon]",
    );
    button.replaceChildren(template?.content.cloneNode(true) ?? "");
    const text = document.createElement("span");
    text.textContent = label;
    button.append(text);
    button.setAttribute(
      "aria-label",
      label === "已复制" ? "代码已复制" : label === "复制失败" ? label : "复制代码",
    );
  }

  function announceCopyResult(button: HTMLButtonElement, label: string, message: string) {
    const status = document.querySelector<HTMLElement>("[data-code-copy-status]");
    setCopyButton(button, label, label === "已复制");
    status?.replaceChildren(message);

    const previousTimer = resetTimers.get(button);
    if (previousTimer) window.clearTimeout(previousTimer);
    resetTimers.set(
      button,
      window.setTimeout(() => setCopyButton(button, "复制", false), 2_000),
    );
  }

  function enhanceCodeBlocks() {
    document.querySelectorAll<HTMLElement>(".prose pre").forEach((codeBlock) => {
      if (codeBlock.dataset.copyEnhanced === "true") return;
      if (codeBlock.closest("[data-code-copy-ignore]")) return;

      const code = codeBlock.querySelector<HTMLElement>("code");
      if (!code) return;

      const toolbar = document.createElement("div");
      toolbar.className = "code-toolbar";
      const language = [...code.classList]
        .find((className) => className.startsWith("language-"))
        ?.replace("language-", "");
      const label = document.createElement("span");
      label.textContent = languageNames[language ?? ""] ?? "Code";

      const button = document.createElement("button");
      button.type = "button";
      button.className = "code-copy-button";
      setCopyButton(button, "复制", false);
      button.addEventListener("click", async () => {
        try {
          if (!navigator.clipboard?.writeText) throw new Error("Clipboard API unavailable");
          await navigator.clipboard.writeText(code.textContent ?? "");
          announceCopyResult(button, "已复制", "代码已复制到剪贴板。");
        } catch {
          announceCopyResult(button, "复制失败", "复制代码失败，请手动选择代码。");
        }
      });

      toolbar.append(label, button);
      codeBlock.dataset.copyEnhanced = "true";
      codeBlock.prepend(toolbar);
    });
  }

  enhanceCodeBlocks();
  document.addEventListener("astro:page-load", enhanceCodeBlocks);
</script>
