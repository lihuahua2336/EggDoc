---
import { Badge } from "@/components/ui/badge";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ExternalLink, Video } from "lucide-react";
import {
  formatDate,
  getEntryKindLabel,
  getEntryUrl,
  type AdjacentEntries,
  type ContentEntry,
} from "@/lib/content";

type Heading = {
  depth: number;
  slug: string;
  text: string;
};

interface Props {
  entry: ContentEntry;
  headings?: Heading[];
  adjacent?: AdjacentEntries;
  related?: ContentEntry[];
}

const { entry, headings = [], adjacent = {}, related = [] } = Astro.props;
const toc = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const canonicalPath = getEntryUrl(entry);
const videoUrl = entry.collection === "lessons" ? entry.data.videoUrl : undefined;
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath={canonicalPath}
  type="article"
>
  <main class="mx-auto grid max-w-6xl gap-8 px-4 py-10 lg:grid-cols-[minmax(0,1fr)_16rem]">
    <article class="min-w-0" data-pagefind-body>
      <nav class="mb-8 text-sm text-muted-foreground">
        <a href="/" class="hover:text-foreground">首页</a>
        <span class="mx-2">/</span>
        <span>{entry.data.title}</span>
      </nav>
      <header class="mb-8 border-b border-border pb-8">
        <div class="mb-4 flex flex-wrap gap-2">
          {entry.data.tags.map((tag) => (
            <a href={`/tags/${tag}/`}>
              <Badge variant="outline">{tag}</Badge>
            </a>
          ))}
        </div>
        <h1 class="text-3xl font-semibold tracking-normal text-foreground md:text-4xl">
          {entry.data.title}
        </h1>
        <p class="mt-4 max-w-3xl text-lg leading-8 text-muted-foreground">
          {entry.data.description}
        </p>
        <div class="mt-5 flex flex-wrap gap-4 text-sm text-muted-foreground">
          <span>发布于 {formatDate(entry.data.publishedAt)}</span>
          <span>更新于 {formatDate(entry.data.updatedAt)}</span>
        </div>
      </header>
      {
        videoUrl && (
          <section
            class="mb-8 flex min-w-0 gap-3 border-y border-border py-4"
            aria-labelledby="lesson-video-heading"
          >
            <Video className="mt-0.5 shrink-0 text-primary" aria-hidden="true" size={20} />
            <div class="min-w-0">
              <h2 id="lesson-video-heading" class="text-sm font-semibold text-foreground">
                课程视频
              </h2>
              <a
                class="mt-1 inline-flex max-w-full items-start gap-1.5 text-sm leading-6 text-primary underline underline-offset-4"
                href={videoUrl}
                target="_blank"
                rel="noopener noreferrer external"
                aria-label="打开课程视频"
              >
                <span class="break-all">{videoUrl}</span>
                <ExternalLink
                  className="mt-1 shrink-0"
                  aria-hidden="true"
                  size={14}
                />
              </a>
            </div>
          </section>
        )
      }
      <div class="prose max-w-none">
        <slot />
      </div>
      <p class="sr-only" aria-live="polite" data-code-copy-status></p>
      {
        (adjacent.previous || adjacent.next) && (
          <nav class="mt-12 grid gap-4 border-t border-border pt-8 md:grid-cols-2" aria-label="课程导航">
            <div>
              {adjacent.previous && (
                <a
                  class="block rounded-lg border border-border bg-card p-4 transition-colors hover:border-primary/50"
                  href={getEntryUrl(adjacent.previous)}
                >
                  <span class="text-xs text-muted-foreground">上一节</span>
                  <p class="mt-2 font-medium">{adjacent.previous.data.title}</p>
                </a>
              )}
            </div>
            <div>
              {adjacent.next && (
                <a
                  class="block rounded-lg border border-border bg-card p-4 text-right transition-colors hover:border-primary/50"
                  href={getEntryUrl(adjacent.next)}
                >
                  <span class="text-xs text-muted-foreground">下一节</span>
                  <p class="mt-2 font-medium">{adjacent.next.data.title}</p>
                </a>
              )}
            </div>
          </nav>
        )
      }
      {
        related.length > 0 && (
          <section class="mt-12 border-t border-border pt-8">
            <h2 class="text-xl font-semibold">继续阅读</h2>
            <div class="mt-4 grid gap-4 md:grid-cols-3">
              {related.map((item) => (
                <a
                  class="rounded-lg border border-border bg-card p-4 transition-colors hover:border-primary/50"
                  href={getEntryUrl(item)}
                >
                  <span class="text-xs text-muted-foreground">{getEntryKindLabel(item)}</span>
                  <p class="mt-2 font-medium leading-6">{item.data.title}</p>
                  <p class="mt-2 line-clamp-2 text-sm leading-6 text-muted-foreground">
                    {item.data.description}
                  </p>
                </a>
              ))}
            </div>
          </section>
        )
      }
    </article>
    <aside class="hidden lg:block">
      <div class="sticky top-24 space-y-4">
        {
          toc.length > 0 && (
            <nav class="rounded-lg border border-border bg-card p-4" aria-label="文章目录">
              <p class="text-sm font-medium">目录</p>
              <ol class="mt-3 space-y-2 text-sm text-muted-foreground">
                {toc.map((heading) => (
                  <li class={heading.depth === 3 ? "pl-3" : ""}>
                    <a class="hover:text-foreground" href={`#${heading.slug}`}>
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          )
        }
        <div class="rounded-lg border border-border bg-card p-4">
          <p class="text-sm font-medium">本文信息</p>
          <dl class="mt-4 space-y-3 text-sm text-muted-foreground">
            <div>
              <dt class="text-xs uppercase tracking-wide">类型</dt>
              <dd class="mt-1">{getEntryKindLabel(entry)}</dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-wide">标签</dt>
              <dd class="mt-1">{entry.data.tags.join(", ")}</dd>
            </div>
          </dl>
        </div>
      </div>
    </aside>
  </main>
</BaseLayout>

<script>
  const resetTimers = new WeakMap<HTMLButtonElement, number>();

  function announceCopyResult(button: HTMLButtonElement, label: string, message: string) {
    const status = document.querySelector<HTMLElement>("[data-code-copy-status]");
    button.textContent = label;
    status?.replaceChildren(message);

    const previousTimer = resetTimers.get(button);
    if (previousTimer) window.clearTimeout(previousTimer);
    resetTimers.set(
      button,
      window.setTimeout(() => {
        button.textContent = "复制代码";
      }, 2_000),
    );
  }

  function enhanceCodeBlocks() {
    document.querySelectorAll<HTMLElement>(".prose pre").forEach((codeBlock) => {
      if (codeBlock.dataset.copyEnhanced === "true") return;
      if (codeBlock.closest("[data-code-copy-ignore]")) return;

      const code = codeBlock.querySelector<HTMLElement>("code");
      if (!code) return;

      const button = document.createElement("button");
      button.type = "button";
      button.className = "code-copy-button";
      button.textContent = "复制代码";
      button.addEventListener("click", async () => {
        try {
          if (!navigator.clipboard?.writeText) throw new Error("Clipboard API unavailable");
          await navigator.clipboard.writeText(code.textContent ?? "");
          announceCopyResult(button, "代码已复制", "代码已复制到剪贴板。");
        } catch {
          announceCopyResult(button, "复制失败", "复制代码失败，请手动选择代码。");
        }
      });

      codeBlock.dataset.copyEnhanced = "true";
      codeBlock.append(button);
    });
  }

  enhanceCodeBlocks();
  document.addEventListener("astro:page-load", enhanceCodeBlocks);
</script>
