{
  "name": "eggdoc",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "build:container": "cross-env EGGDOC_DEPLOY_TARGET=node npm run build",
    "build:test": "cross-env CLOUDFLARE_ENV=test astro check && cross-env CLOUDFLARE_ENV=test astro build --mode test && pagefind --site dist/client",
    "env:container": "node scripts/create-container-env.mjs",
    "preview": "astro preview",
    "start:container": "node dist/server/entry.mjs",
    "check": "astro check",
    "test": "npm run build:test && playwright test tests/e2e tests/install tests/unit && npm run test:preview",
    "test:e2e": "npm run build:test && playwright test tests/e2e",
    "test:preview": "npm run build && playwright test tests/preview",
    "postbuild": "pagefind --site dist/client && node tests/fixtures/assert-production-content.mjs",
    "deploy:cloudflare": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.3",
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/node": "^11.0.2",
    "@astrojs/react": "^6.0.1",
    "@astrojs/sitemap": "^3.7.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "openid-client": "^6.8.4",
    "pagefind": "^1.5.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "jose": "^6.2.2",
    "typescript": "^6.0.3",
    "wrangler": "^4.110.0",
    "yaml": "^2.9.0"
  }
}
