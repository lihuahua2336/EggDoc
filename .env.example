# Public site origin used by the container deployment
EGGDOC_SITE_URL=https://docs.example.com
EGGDOC_IMAGE=ghcr.io/lihuahua2336/eggdoc:1.0

# Dedicated EggDoc Logto application
EGGDOC_OIDC_ISSUER=https://your-logto-tenant.example.com/oidc
EGGDOC_OIDC_CLIENT_ID=your-eggdoc-client-id
EGGDOC_OIDC_CLIENT_SECRET=your-eggdoc-client-secret
EGGDOC_OIDC_RESOURCE=https://api.eggai.icu/api
EGGDOC_OIDC_SCOPES="openid profile offline_access ecosystem:me ecosystem:models:read ecosystem:tokens:read"

# Generate a unique 32-byte Base64URL value; do not reuse this example.
EGGDOC_SESSION_SECRET=replace-with-a-32-byte-base64url-secret

# Real EggAi services used by the localhost acceptance pass
EGGDOC_EGGAI_PLATFORM_URL=https://api.eggai.icu
EGGDOC_EGGAI_ECOSYSTEM_URL=https://api.eggai.icu

# Optional public configuration
PUBLIC_EGGAI_BASE_URL=https://api.eggai.icu/v1
PUBLIC_INSTALLER_ORIGIN=https://eggdoc.pages.dev
# Optional China-accessible upstream installer mirrors used by generated commands.
# PUBLIC_CODEX_INSTALLER_ORIGIN=https://mirror.example.com/codex
# PUBLIC_CLAUDE_CODE_INSTALLER_ORIGIN=https://mirror.example.com/claude
